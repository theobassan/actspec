{
  "name": "@actharness/expressions",
  "version": "0.1.0",
  "license": "MIT",
  "description": "GitHub Actions ${{ }} expression engine — standalone, zero runtime deps",
  "repository": {
    "type": "git",
    "url": "https://github.com/actharness/actharness",
    "directory": "packages/expressions"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "api-report": "api-extractor run --local",
    "api-check": "api-extractor run"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@microsoft/api-extractor": "^7.58.8",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.8",
    "fast-check": "^4.8.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
