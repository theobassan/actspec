{
  "name": "actharness",
  "version": "0.1.0",
  "license": "MIT",
  "description": "GitHub Actions unit testing framework — meta package",
  "repository": {
    "type": "git",
    "url": "https://github.com/actharness/actharness",
    "directory": "packages/actharness"
  },
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./globals": "./globals.d.ts"
  },
  "files": [
    "dist",
    "globals.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actharness/cli": "workspace:*",
    "@actharness/composite": "workspace:*",
    "@actharness/core": "workspace:*",
    "@actharness/fixtures": "workspace:*",
    "@actharness/matchers": "workspace:*",
    "@actharness/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
