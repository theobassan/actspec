{
  "name": "@actharness/coverage",
  "version": "0.1.0",
  "license": "MIT",
  "description": "actharness Istanbul coverage collector — maps action steps to statements/branches",
  "repository": {
    "type": "git",
    "url": "https://github.com/actharness/actharness",
    "directory": "packages/coverage"
  },
  "type": "module",
  "sideEffects": [
    "./dist/register.js",
    "./dist/register.cjs"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./register": {
      "import": {
        "types": "./dist/register.d.ts",
        "default": "./dist/register.js"
      },
      "require": {
        "types": "./dist/register.d.cts",
        "default": "./dist/register.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@actharness/core": "workspace:*",
    "@actharness/types": "workspace:*",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
