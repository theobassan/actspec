{
  "name": "actharness",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' build",
    "typecheck": "pnpm -r --filter='./packages/*' typecheck",
    "test": "pnpm -r --filter='./packages/*' test && pnpm --filter='./fixtures' test",
    "lint": "eslint packages/*/src packages/*/test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  }
}
